function kcrusade() {
  TYPE=$argv[1]
  NAME=$argv[2]
  NAMESPACE=$kns

  printf "\nTargets: \e[1;35m$TYPE\e[0m \e[1;33m$NAME\e[0m\n"
  read "EXCECUTE_EXCECUTION?Do ye wish to kill all $TYPE with this name? [y/N] "
  if [[ "$EXCECUTE_EXCECUTION" =~ ^[Yy]$ ]]
  then
    printf "\n\e[0;32mᕕ( ᐛ ) ᕗ Commencing Crusade! \e[0m\n"
    kubectl $kns delete $TYPE $(kubectl $NAMESPACE get pods | grep $NAME | awk '{print $1}')
  fi
}
